{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../frontend",
    "distDir": "../frontend"
  },
  "package": {
    "productName": "JS Intelligence Platform",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/js-intelligence-server",
            "sidecar": true,
            "args": true
          }
        ]
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "setTitle": true
      },
      "http": {
        "all": true,
        "scope": ["http://localhost:8787/*", "ws://localhost:8787/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.jsintelligence.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ],
      "resources": [],
      "externalBin": ["binaries/js-intelligence-server"],
      "copyright": "",
      "category": "DeveloperTool",
      "shortDescription": "Bug bounty JS intelligence & secret scanning",
      "longDescription": "Automated recon, JavaScript discovery, and secret/PII detection platform for authorized security research."
    },
    "security": {
      "csp": "default-src 'self' http://localhost:8787 ws://localhost:8787; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "JS Intelligence Platform",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
